# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Local Streamlit secrets (use secrets.toml.example as the template)
.streamlit/secrets.toml

# OS / editor noise
Thumbs.db
.DS_Store
.vscode/
.idea/

# Debug / smoke outputs
tmp/
_streamlit*.log
_index.html
_health.txt
ts_debug_*.txt
ts_smoke_*.txt
smoke_run_out.txt

# Large data archives that do not belong in source control.
# Note: ML checkpoints (*.pth) are tracked via Git LFS — see .gitattributes.
*.zip
*.pptx

# Supabase CLI workspace state (project-local, machine-specific).
supabase/.temp/
supabase/.branches/

# Curation output (per-release packs are artifacts, not source).
curated/

# Ignore the 260429 measurement archive by default, but allow the 8 cross-section
# text files the app needs at runtime. Patterns are walked downward — never
# ignore a directory you want to descend into.
/260429/*
!/260429/260429_analysis_OAS/
/260429/260429_analysis_OAS/*
!/260429/260429_analysis_OAS/Cross_sections_modified/
/260429/260429_analysis_OAS/Cross_sections_modified/*
!/260429/260429_analysis_OAS/Cross_sections_modified/*_ordered_cross_section.txt
