# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Local Streamlit secrets (use secrets.toml.example as the template)
.streamlit/secrets.toml

# OS / editor noise
Thumbs.db
.DS_Store
.vscode/
.idea/

# Debug / smoke outputs
tmp/
_streamlit*.log
_index.html
_health.txt
ts_debug_*.txt
ts_smoke_*.txt
smoke_run_out.txt

# Large data archives that do not belong in source control.
# Note: ML checkpoints (*.pth) are tracked via Git LFS — see .gitattributes.
*.zip
*.pptx

# Supabase CLI workspace state (project-local, machine-specific).
supabase/.temp/
supabase/.branches/

# Curation output (per-release packs are artifacts, not source).
curated/

# The Cross_sections_modified folder at the repo root carries the 8 reference
# spectra the app needs at runtime. Anything else dropped into it is ignored.
/Cross_sections_modified/*
!/Cross_sections_modified/*_ordered_cross_section.txt

# Raw video export from CapCut (not part of the repo)
/Demo_final.mp4
