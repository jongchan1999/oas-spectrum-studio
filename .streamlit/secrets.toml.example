# Copy this file to `secrets.toml` (kept gitignored) and edit the credentials.
# In Streamlit Community Cloud, paste the same content into:
#   App settings → Secrets

[auth]
enabled = true

# Option A (single user, backward compatible)
# username = "your-username"
# password = "replace-with-strong-password"

# Option B (multiple allowed users — recommended for an allow-list)
users = { "alice" = "pw1", "bob" = "pw2" }
