# Copy this file to `secrets.toml` (kept gitignored) and edit the values.
# In Streamlit Community Cloud, paste the same content into:
#   App settings → Secrets

# ─── Allow-list login ────────────────────────────────────────────────
[auth]
enabled = true

# Option A (single user, backward compatible)
# username = "your-username"
# password = "replace-with-strong-password"

# Option B (multiple allowed users — recommended for an allow-list)
users = { "alice" = "pw1", "bob" = "pw2" }


# ─── Continual-learning submission endpoint ──────────────────────────
# Fill in once the Supabase project + edge function are deployed. Until
# then, leave blank or omit the [cl] section — the app falls back to the
# local CSV-only flow and shows a "submission portal not configured"
# caption.
#
# `endpoint` is the public URL of the `submit` edge function:
#   https://<project-ref>.functions.supabase.co/submit
# `anon_key` is the project's *anon* public API key (Settings → API).
#
# [cl]
# endpoint = "https://YOUR-PROJECT-REF.functions.supabase.co/submit"
# anon_key = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...."
