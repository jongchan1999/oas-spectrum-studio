# Git LFS tracking — large ML checkpoints belong in LFS, not regular history.
# Required because GitHub rejects single files larger than 100 MB in normal
# blob storage. Run `git lfs install` once per machine before cloning.
*.pth filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# Demo video — keep portable + offline-friendly; track via LFS so the
# repo stays small while the README still embeds a playable <video>.
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text

# Normalize line endings on text files so Windows checkouts don't churn diffs.
* text=auto eol=lf
*.bat text eol=crlf
*.png binary
*.jpg binary
*.svg text eol=lf
